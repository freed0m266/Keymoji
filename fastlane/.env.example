# App Store Connect API key — copy to fastlane/.env and fill in.
# fastlane auto-loads fastlane/.env; the real .env is gitignored.
#
# Generate the key in App Store Connect:
#   Users and Access → Integrations → App Store Connect API → (+)
#   Role: App Manager (or Admin). Download the AuthKey_XXXXXXXXXX.p8 ONCE.

# The 10-char Key ID shown next to the key in the list.
ASC_KEY_ID=XXXXXXXXXX

# The Issuer ID (UUID) shown at the top of the Integrations / Keys page.
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the downloaded .p8 file. Keep it OUTSIDE git, e.g.
#   ~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
ASC_KEY_FILEPATH=/Users/martin/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
